---
import Layout from "../layouts/Layout.astro";
import Container from "../components/container.astro";

const categories = [
  { name: "Constitución y Registro", start: 1, end: 20 },
  { name: "Cambios y Reformas", start: 21, end: 40 },
  { name: "Certificados y Copias", start: 41, end: 60 },
  { name: "Cumplimiento y Obligaciones", start: 61, end: 80 },
  { name: "Cierre y Liquidación", start: 81, end: 100 },
];

function slugifyTramite(n) {
  return `tramite-comun-${n}`;
}

function buildGridHTML() {
  return categories
    .map((cat) => {
      const items = Array.from({ length: cat.end - cat.start + 1 }, (_, i) => {
        const n = cat.start + i;
        const name = `Trámite Común ${n}`;
        const href = `/tramites/${slugifyTramite(n)}`;
        const catLower = cat.name.toLowerCase();

        return `
          <li class="tramiteItem" data-name="${name.toLowerCase()}" data-category="${catLower}">
            <a class="itemLink" href="${href}">
              <span>${name}</span>
              <span class="badge">${cat.name}</span>
            </a>
          </li>
        `;
      }).join("");

      return `
        <div class="card" data-category="${cat.name.toLowerCase()}">
          <h2 class="catTitle">${cat.name}</h2>
          <ul>${items}</ul>
        </div>
      `;
    })
    .join("");
}

const gridHTML = buildGridHTML();
---

<Layout title="Todos los trámites">
  <Container>
    <main class="wrap">
      <h1>Todos los trámites</h1>

      <div class="searchRow">
        <input
          id="tramiteSearch"
          type="search"
          placeholder="Buscar por nombre o categoría (ej: “común 12”, “reformas”, “cierre”)…"
          aria-label="Buscar trámites"
        />
        <div class="count"><span id="matchCount">100</span> / 100</div>
      </div>

      <div id="noResults" class="noResults hidden">
        No se encontraron trámites con ese criterio.
      </div>

      <section class="grid" id="tramitesGrid" set:html={gridHTML}></section>

      <script>
        const input = document.getElementById("tramiteSearch");
        const items = Array.from(document.querySelectorAll(".tramiteItem"));
        const cards = Array.from(document.querySelectorAll(".card"));
        const matchCount = document.getElementById("matchCount");
        const noResults = document.getElementById("noResults");

        function normalize(s) {
          return (s || "")
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "");
        }

        function applyFilter() {
          const q = normalize(input.value.trim());
          let matches = 0;

          for (const li of items) {
            const name = normalize(li.dataset.name);
            const category = normalize(li.dataset.category);
            const ok = !q || name.includes(q) || category.includes(q);
            li.classList.toggle("hidden", !ok);
            if (ok) matches++;
          }

          for (const card of cards) {
            const visible = card.querySelectorAll(".tramiteItem:not(.hidden)").length > 0;
            card.classList.toggle("hidden", !visible);
          }

          matchCount.textContent = String(matches);
          noResults.classList.toggle("hidden", matches !== 0);
        }

        input.addEventListener("input", applyFilter);
      </script>
    </main>
  </Container>
</Layout>

<style>
  .wrap { max-width: 960px; margin: 0 auto; padding: 2rem 1rem; }
  h1 { font-size: 2rem; margin: 0 0 1rem; }
  .searchRow { display: flex; gap: .75rem; align-items: center; margin: 1rem 0 1.25rem; }
  input[type="search"] {
    width: 100%;
    padding: .75rem .9rem;
    border: 1px solid #D8DEE9;
    border-radius: .6rem;
    font-size: 1rem;
  }
  .count { font-size: .95rem; opacity: .8; white-space: nowrap; }
  .grid { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  @media (min-width: 900px) { .grid { grid-template-columns: 1fr 1fr; } }

  .card {
    border: 1px solid rgba(216,222,233,.9);
    border-radius: .8rem;
    padding: 1rem;
  }
  .catTitle { font-size: 1.05rem; margin: 0 0 .75rem; opacity: .85; }
  ul { list-style: none; padding: 0; margin: 0; display: grid; gap: .5rem; }
  a { text-decoration: none; color: inherit; }
  .itemLink {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: .55rem .65rem;
    border-radius: .55rem;
  }
  .itemLink:hover { background: rgba(216,222,233,.35); }
  .badge { font-size: .8rem; opacity: .75; }
  .hidden { display: none !important; }
  .noResults { margin-top: 1rem; padding: 1rem; border: 1px dashed rgba(216,222,233,.9); border-radius: .8rem; opacity: .85; }
</style>
