---
import Layout from "../layouts/Layout.astro";
import Container from "../components/container.astro";

// @ts-ignore
import { Icon } from "astro-icon/components";

const services = [
  {
    title: "Sitios web (WordPress / Astro)",
    description:
      "Sitios de marketing rapidos, landing pages, blogs y paginas optimizadas para SEO para negocios locales.",
    icon: "bx:bxs-layout",
    href: "/servicios-digitales/websites",
  },
  {
    title: "Portal de clientes (React + Firebase)",
    description:
      "Acceso con login y paneles para que tus clientes vean documentos, avances y novedades en un solo lugar.",
    icon: "bx:bxs-dashboard",
    href: "/servicios-digitales/portal",
  },
  {
    title: "Automatizacion (Zapier / Make)",
    description:
      "Automatiza tareas repetitivas: formularios -> WhatsApp/email, actualizaciones de CRM, recordatorios y facturas.",
    icon: "bx:bxs-cog",
    href: "/servicios-digitales/automatizacion",
  },
  {
    title: "Comercio electronico (Shopify)",
    description:
      "Configuracion de tienda online, productos, colecciones, pagos, envios e integraciones basicas.",
    icon: "bx:bxs-store",
    href: "/servicios-digitales/ecommerce",
  },
  {
    title: "Contenido con IA y flujos de trabajo",
    description:
      "Sistemas de contenido, plantillas y flujos asistidos con IA para ahorrar tiempo sin perder calidad.",
    icon: "bx:bxs-brain",
    href: "/servicios-digitales/ai",
  },
  {
    title: "Mantenimiento y soporte",
    description:
      "Actualizaciones, respaldos, cambios menores, mejoras de rendimiento y soporte continuo.",
    icon: "bx:bxs-wrench",
    href: "/servicios-digitales/soporte",
  },
];
---

<Layout title="Servicios Digitales">
  <Container>
    <section class="py-16">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-[#F15D2D]">Agiliza</p>
        <h1 class="text-3xl font-semibold tracking-tight mt-2">
          Servicios Digitales
        </h1>
        <p class="mt-4 text-base opacity-80">
          Servicios digitales practicos para pequenas empresas: sitios web, portales, automatizacion y comercio electronico.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href="/contact"
            class="inline-flex items-center rounded-lg px-4 py-2 text-sm font-medium bg-[#F15D2D] text-white hover:bg-[#d94f23] transition-colors"
          >
            Solicitar cotizacion
          </a>
          <a
            href="/pricing"
            class="inline-flex items-center rounded-lg px-4 py-2 text-sm font-medium border border-[#F15D2D] text-[#F15D2D] hover:bg-[#fff2ed] transition-colors"
          >
            Ver precios
          </a>
        </div>
      </div>

      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((s) => (
          <a
            href={s.href}
            class="group rounded-2xl border border-black/10 p-5 hover:border-[#F15D2D] transition"
          >
            <div class="flex items-start gap-3">
              <div class="rounded-xl border border-black/10 p-2 group-hover:border-[#F15D2D] transition-colors">
                <Icon name={s.icon} class="h-6 w-6" />
              </div>

              <div>
                <h2 class="text-base font-semibold group-hover:text-[#F15D2D] group-hover:underline transition-colors">
                  {s.title}
                </h2>
                <p class="mt-2 text-sm opacity-80">
                  {s.description}
                </p>

                <p class="mt-4 text-sm font-medium opacity-80">
                  Saber mas ->
                </p>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-14 rounded-2xl border border-black/10 p-6">
        <h3 class="text-lg font-semibold">No estas seguro de lo que necesitas?</h3>
        <p class="mt-2 text-sm opacity-80">
          Cuentame sobre tu negocio y objetivo. Te recomiendo el stack mas simple (WordPress/Astro/React) que genere resultados.
        </p>
        <a
          href="/contact"
          class="mt-4 inline-flex items-center rounded-lg px-4 py-2 text-sm font-medium border border-[#F15D2D] text-[#F15D2D] hover:bg-[#fff2ed] transition-colors"
        >
          Contacto
        </a>
      </div>
    </section>
  </Container>
</Layout>
