---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
---

<Layout title="Conexiones Coworking - Ibarra">
  <!-- Hero -->
  <section class="bg-white pt-20 pb-16">
    <Container>
      <div class="flex flex-col items-center text-center gap-6">
        <img
          src="/Captura de pantalla 2026-03-05 183359.png"
          alt="Conexiones Coworking"
          class="h-24 object-contain"
        />
        <h1 class="text-4xl md:text-5xl font-bold text-gray-800 max-w-3xl leading-tight">
          Tu espacio de trabajo en <span style="color:#4285F4">I</span><span style="color:#EA4335">b</span><span style="color:#FBBC05">a</span><span style="color:#34A853">r</span><span style="color:#EA4335">r</span><span style="color:#4285F4">a</span>
        </h1>
        <p class="text-xl text-slate-500 max-w-2xl">
          Un coworking diseñado para emprendedores, freelancers y equipos que buscan un ambiente productivo, colaborativo e inspirador en el corazón de Ibarra.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mt-2">
          <a
            href="#contacto"
            class="rounded-full px-8 py-3 text-white font-semibold text-lg transition"
            style="background:#4285F4"
          >
            Reserva tu espacio
          </a>
          <a
            href="#planes"
            class="rounded-full px-8 py-3 font-semibold text-lg border-2 transition hover:bg-gray-50"
            style="color:#4285F4; border-color:#4285F4"
          >
            Ver planes
          </a>
        </div>
      </div>
    </Container>
  </section>

  <!-- ¿Qué es Conexiones? -->
  <section class="bg-slate-50 py-20" id="nosotros">
    <Container>
      <div class="flex flex-col md:flex-row items-center gap-12">
        <div class="flex-1">
          <div class="inline-block rounded-full px-4 py-1 text-sm font-semibold mb-4" style="background:#E8F0FE; color:#4285F4">
            ¿Quiénes somos?
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4">
            Más que una oficina, una comunidad
          </h2>
          <p class="text-slate-500 text-lg leading-relaxed mb-4">
            Conexiones Coworking nació con la misión de ofrecer un espacio moderno, flexible y asequible en Ibarra. Sabemos que trabajar desde casa puede ser un reto, y que rentar una oficina tradicional es costoso.
          </p>
          <p class="text-slate-500 text-lg leading-relaxed">
            Por eso creamos un lugar donde puedes conectarte con otros profesionales, acceder a infraestructura de calidad y ser parte de una comunidad que impulsa tu crecimiento.
          </p>
        </div>
        <div class="flex-1 grid grid-cols-2 gap-4">
          <div class="rounded-2xl p-6 bg-white shadow-sm flex flex-col items-center text-center gap-2">
            <span class="text-3xl font-bold" style="color:#4285F4">50+</span>
            <span class="text-slate-500 text-sm">Miembros activos</span>
          </div>
          <div class="rounded-2xl p-6 bg-white shadow-sm flex flex-col items-center text-center gap-2">
            <span class="text-3xl font-bold" style="color:#EA4335">12</span>
            <span class="text-slate-500 text-sm">Salas y puestos</span>
          </div>
          <div class="rounded-2xl p-6 bg-white shadow-sm flex flex-col items-center text-center gap-2">
            <span class="text-3xl font-bold" style="color:#FBBC05">24/7</span>
            <span class="text-slate-500 text-sm">Acceso disponible</span>
          </div>
          <div class="rounded-2xl p-6 bg-white shadow-sm flex flex-col items-center text-center gap-2">
            <span class="text-3xl font-bold" style="color:#34A853">100%</span>
            <span class="text-slate-500 text-sm">Fibra óptica</span>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Amenidades -->
  <section class="bg-white py-20" id="servicios">
    <Container>
      <div class="text-center mb-14">
        <div class="inline-block rounded-full px-4 py-1 text-sm font-semibold mb-4" style="background:#E6F4EA; color:#34A853">
          Servicios
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-800">
          Todo lo que necesitas para trabajar
        </h2>
        <p class="text-slate-500 text-lg mt-3 max-w-xl mx-auto">
          Infraestructura profesional pensada para que te concentres en lo que importa.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: "wifi", color: "#4285F4", bg: "#E8F0FE", title: "Internet de alta velocidad", desc: "Fibra óptica simétrica con backup para que nunca pierdas la conexión." },
          { icon: "coffee", color: "#EA4335", bg: "#FCE8E6", title: "Café y snacks", desc: "Disfruta de café ilimitado, agua y snacks saludables durante tu jornada." },
          { icon: "meeting", color: "#FBBC05", bg: "#FEF7E0", title: "Sala de reuniones", desc: "Reserva nuestra sala equipada con TV, proyector y pizarrón." },
          { icon: "print", color: "#34A853", bg: "#E6F4EA", title: "Impresión y escaneo", desc: "Acceso a impresoras láser y escáner sin costo adicional." },
          { icon: "locker", color: "#4285F4", bg: "#E8F0FE", title: "Lockers seguros", desc: "Guarda tus pertenencias con seguridad en nuestros casilleros." },
          { icon: "event", color: "#EA4335", bg: "#FCE8E6", title: "Eventos y networking", desc: "Participa en talleres, charlas y eventos de la comunidad Conexiones." },
        ].map((item) => (
          <div class="rounded-2xl border border-gray-100 p-6 hover:shadow-md transition">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4" style={`background:${item.bg}`}>
              {item.icon === "wifi" && (
                <svg class="w-6 h-6" fill="none" stroke={item.color} stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.14 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"/></svg>
              )}
              {item.icon === "coffee" && (
                <svg class="w-6 h-6" fill="none" stroke={item.color} stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8zM6 1v3M10 1v3M14 1v3"/></svg>
              )}
              {item.icon === "meeting" && (
                <svg class="w-6 h-6" fill="none" stroke={item.color} stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              )}
              {item.icon === "print" && (
                <svg class="w-6 h-6" fill="none" stroke={item.color} stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
              )}
              {item.icon === "locker" && (
                <svg class="w-6 h-6" fill="none" stroke={item.color} stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
              )}
              {item.icon === "event" && (
                <svg class="w-6 h-6" fill="none" stroke={item.color} stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              )}
            </div>
            <h3 class="font-semibold text-gray-800 text-lg mb-1">{item.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Planes -->
  <section class="bg-slate-50 py-20" id="planes">
    <Container>
      <div class="text-center mb-14">
        <div class="inline-block rounded-full px-4 py-1 text-sm font-semibold mb-4" style="background:#FEF7E0; color:#F9A825">
          Planes
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-800">
          Elige el plan que se adapta a ti
        </h2>
        <p class="text-slate-500 text-lg mt-3 max-w-xl mx-auto">
          Planes flexibles para freelancers, emprendedores y empresas en crecimiento.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <!-- Plan Día -->
        <div class="bg-white rounded-2xl border border-gray-200 p-8 flex flex-col gap-4">
          <div>
            <h3 class="text-xl font-bold text-gray-800">Día</h3>
            <p class="text-slate-500 text-sm mt-1">Perfecto para visitantes y trabajo ocasional</p>
          </div>
          <div>
            <span class="text-4xl font-bold text-gray-800">$8</span>
            <span class="text-slate-500 text-sm"> / día</span>
          </div>
          <ul class="flex flex-col gap-2 text-sm text-slate-600 flex-1">
            {["Puesto en área abierta", "WiFi de alta velocidad", "Café incluido", "Acceso 8h00 - 20h00"].map(f => (
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="#34A853" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="#contacto" class="mt-2 w-full text-center rounded-full py-3 font-semibold border-2 transition hover:bg-gray-50" style="color:#4285F4; border-color:#4285F4">
            Empezar
          </a>
        </div>

        <!-- Plan Mensual -->
        <div class="bg-white rounded-2xl border-2 p-8 flex flex-col gap-4 relative shadow-lg" style="border-color:#4285F4">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 rounded-full px-4 py-1 text-xs font-bold text-white" style="background:#4285F4">
            MAS POPULAR
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-800">Mensual</h3>
            <p class="text-slate-500 text-sm mt-1">Para profesionales que necesitan estabilidad</p>
          </div>
          <div>
            <span class="text-4xl font-bold text-gray-800">$120</span>
            <span class="text-slate-500 text-sm"> / mes</span>
          </div>
          <ul class="flex flex-col gap-2 text-sm text-slate-600 flex-1">
            {["Puesto fijo o flexible", "WiFi de alta velocidad", "Café y snacks incluidos", "2 horas de sala de reuniones", "Locker personal", "Acceso 24/7", "Comunidad y eventos"].map(f => (
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="#34A853" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="#contacto" class="mt-2 w-full text-center rounded-full py-3 font-semibold text-white transition" style="background:#4285F4">
            Empezar
          </a>
        </div>

        <!-- Plan Oficina Privada -->
        <div class="bg-white rounded-2xl border border-gray-200 p-8 flex flex-col gap-4">
          <div>
            <h3 class="text-xl font-bold text-gray-800">Oficina Privada</h3>
            <p class="text-slate-500 text-sm mt-1">Para equipos que necesitan privacidad</p>
          </div>
          <div>
            <span class="text-4xl font-bold text-gray-800">$280</span>
            <span class="text-slate-500 text-sm"> / mes</span>
          </div>
          <ul class="flex flex-col gap-2 text-sm text-slate-600 flex-1">
            {["Oficina privada para hasta 4 personas", "WiFi dedicado", "Café y snacks incluidos", "5 horas de sala de reuniones", "Lockers personales", "Acceso 24/7", "Dirección comercial", "Soporte prioritario"].map(f => (
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="#34A853" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="#contacto" class="mt-2 w-full text-center rounded-full py-3 font-semibold border-2 transition hover:bg-gray-50" style="color:#4285F4; border-color:#4285F4">
            Consultar
          </a>
        </div>
      </div>
    </Container>
  </section>

  <!-- Ubicación -->
  <section class="bg-white py-20" id="ubicacion">
    <Container>
      <div class="flex flex-col md:flex-row items-center gap-12">
        <div class="flex-1">
          <div class="inline-block rounded-full px-4 py-1 text-sm font-semibold mb-4" style="background:#FCE8E6; color:#EA4335">
            Ubicacion
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4">
            Estamos en Ibarra
          </h2>
          <p class="text-slate-500 text-lg leading-relaxed mb-6">
            En el centro de Ibarra, con facil acceso en transporte publico y parqueo cercano. Ven a conocernos y te regalamos un dia de prueba gratis.
          </p>
          <div class="flex flex-col gap-3 text-slate-600">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full flex items-center justify-center shrink-0" style="background:#E8F0FE">
                <svg class="w-5 h-5" fill="none" stroke="#4285F4" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <span>Ibarra, Imbabura, Ecuador</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full flex items-center justify-center shrink-0" style="background:#E6F4EA">
                <svg class="w-5 h-5" fill="none" stroke="#34A853" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <span>Lunes a Viernes: 7h00 - 22h00 | Sabado: 8h00 - 18h00</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full flex items-center justify-center shrink-0" style="background:#FCE8E6">
                <svg class="w-5 h-5" fill="none" stroke="#EA4335" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <span>+593 99 000 0000</span>
            </div>
          </div>
        </div>
        <div class="flex-1 rounded-2xl overflow-hidden shadow-md w-full aspect-video bg-slate-100 flex items-center justify-center">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15951.19!2d-78.1226!3d0.3516!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e2a1f9c1e0b0001%3A0x1234!2sIbarra%2C%20Imbabura!5e0!3m2!1ses!2sec!4v1"
            width="100%"
            height="100%"
            style="border:0; min-height:320px;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </Container>
  </section>

  <!-- Contacto / CTA -->
  <section class="py-20" id="contacto" style="background:linear-gradient(135deg,#4285F4 0%,#34A853 100%)">
    <Container>
      <div class="flex flex-col items-center text-center gap-6">
        <img
          src="/Captura de pantalla 2026-03-05 183359.png"
          alt="Conexiones Coworking"
          class="h-16 object-contain brightness-0 invert"
        />
        <h2 class="text-3xl md:text-4xl font-bold text-white max-w-2xl">
          Listo para conectarte con tu mejor version?
        </h2>
        <p class="text-blue-100 text-lg max-w-xl">
          Agenda una visita gratuita y descubre por que Conexiones es el espacio de trabajo ideal en Ibarra.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mt-2">
          <a
            href="https://wa.me/593990000000"
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full px-8 py-3 font-semibold text-lg bg-white transition hover:bg-blue-50"
            style="color:#4285F4"
          >
            WhatsApp
          </a>
          <a
            href="mailto:hola@conexionescoworking.ec"
            class="rounded-full px-8 py-3 font-semibold text-lg border-2 border-white text-white transition hover:bg-white/10"
          >
            Escribenos
          </a>
        </div>
      </div>
    </Container>
  </section>
</Layout>
