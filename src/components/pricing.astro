---
import { Tick } from "@/components/ui/icons";
import Link from "@/components/ui/link.astro";

const { plan } = Astro.props;

// Only for Trámites Legales: map feature text -> price label (edit these values)
const tramitesLegalesFeaturePrices = {
  "All Free Features": "$120",
  "Up to 20 users": "$322",
  "20 Custom domains": "$3",
  "Unlimited Collaborators": "$4",
  "Advanced Integrations": "$5",
};
---

<div>
  <div
    class="flex flex-col w-full order-first lg:order-none border-2 border-[#D8DEE9] border-opacity-50 py-5 px-6 rounded-md"
  >
    <div class="text-center">
      <h4 class="text-lg font-medium text-black">{plan.name}</h4>
    </div>

    <ul class="grid mt-8 text-left gap-y-4">
      {plan.features.map((item) => (
        <li class="text-gray-800">
          {plan.name === "Trámites Legales" && item === "Priority Support" ? (
            <a href="/tramites" class="font-medium text-[#F15D2D] hover:text-[#d94f23] hover:underline">
              Todos los trámites
            </a>
          ) : plan.name === "Trámites Legales" ? (
            <div class="flex items-baseline gap-3">
              <span class="shrink-0">{item}</span>

              <span class="flex-1 border-b border-dotted border-gray-300 opacity-70 translate-y-[-2px]"></span>

              <span class="shrink-0 font-medium text-gray-900">
                {tramitesLegalesFeaturePrices[item] ?? ""}
              </span>
            </div>
          ) : (
            <div class="flex items-start gap-3">
              <Tick class="w-6 h-6" />
              <span>{item}</span>
            </div>
          )}
        </li>
      ))}
    </ul>

    <div class="flex mt-8">
      <Link
        href={plan.button.link || "#"}
        block
        style={plan.popular ? "primary" : "outline"}
      >
        {plan.button.text || "Get Started"}
      </Link>
    </div>
  </div>
</div>
