---
// @ts-ignore
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "Desarrollo de Software",
    description:
      "Sitios web, aplicaciones, portales de clientes, ecommerce y automatizaciones — construidos con tecnología moderna a un costo que las PYMEs pueden pagar.",
    icon: "bx:bxs-layer",
    href: "/desarrollo-de-software",
    items: [
      "Sitios web (Astro / WordPress)",
      "Aplicaciones web (React + Firebase)",
      "Automatización (Zapier / Make / n8n)",
      "Flujos de trabajo con IA",
    ],
  },
  {
    title: "Marketing Digital",
    description:
      "Presencia online constante, publicidad efectiva y generación de leads — sin pagar una agencia tradicional de $700 al mes.",
    icon: "bx:bxs-megaphone",
    href: "/marketing-digital",
    items: [
      "Gestión de redes sociales",
      "Meta Ads y generación de leads",
      "Contenido asistido por IA",
      "Integración con WhatsApp",
    ],
  },
];
---

<div class="mt-16 md:mt-0">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    Dos áreas, un solo objetivo
  </h2>
  <p class="text-lg mt-4 text-slate-600 max-w-2xl">
    Construimos tu presencia digital y automatizamos tus procesos para que puedas
    enfocarte en hacer crecer tu negocio.
  </p>
</div>

<div class="grid sm:grid-cols-2 mt-16 gap-12">
  {
    features.map((item) => (
      <div class="flex gap-4 items-start">
        <div class="mt-1 bg-[#F15D2D] rounded-full p-2 w-8 h-8 shrink-0">
          <Icon class="text-white" name={item.icon} />
        </div>
        <div>
          <h3 class="font-semibold text-lg">{item.title}</h3>
          <p class="text-slate-500 mt-2 leading-relaxed">{item.description}</p>
          <ul class="mt-3 space-y-1">
            {item.items.map((label) => (
              <li class="text-sm text-slate-500 before:content-['—'] before:mr-2 before:text-[#F15D2D]">
                {label}
              </li>
            ))}
          </ul>
          <a
            href={item.href}
            class="mt-4 inline-block text-sm font-medium text-[#F15D2D] hover:underline"
          >
            Ver todos los servicios →
          </a>
        </div>
      </div>
    ))
  }
</div>
