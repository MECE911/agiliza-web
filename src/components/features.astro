---
// @ts-ignore
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "Servicios Digitales",
    description: `
      COnstruye tu sitio usando React, Svelte, Vue, Preact, web components, or just plain ol' HTML + JavaScript.
      Consulta todos nuestros servicios haciendo click
      <a href="/servicios-digitales" class="underline font-medium">aquí</a>
    `,
    icon: "bx:bxs-briefcase",
  },
  {
    title: "Trámites Legales",
    items: [
      { label: "- Constitute una SAS.", href: "/tramites/tramite-comun-1" },
      { label: "- Registra tu marca.", href: "/tramites/tramite-comun-2" },
      { label: "- Trámite Común 3", href: "/tramites/tramite-comun-3" },
      { label: "Todos los trámites", href: "/tramites" },
    ],
    icon: "bx:bxs-window-alt",
  },
  {
    title: "Casos Jurídicos",
    description:
      "Asesoría legal personalizada? Hazlo tu mismo o contacta un abogado real que te ayudará con tu caso haciendo click aquí.",
    icon: "bx:bxs-data",
  },
];
---

<div class="mt-16 md:mt-0">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    Todo lo que necesitas para modernizar tu negocio
  </h2>
  <p class="text-lg mt-4 text-slate-600">
    Creemos que muchas soluciones pueden hacerse por uno mismo con la ayuda de la
tecnología.

  </p>
</div>

<div class="grid sm:grid-cols-2 md:grid-cols-3 mt-16 gap-16">
  {
    features.map((item) => (
      <div class="flex gap-4 items-start">
        <div class="mt-1 bg-[#F15D2D] rounded-full  p-2 w-8 h-8 shrink-0">
          <Icon class="text-white" name={item.icon} />
        </div>
        <div>
          <h3 class="font-semibold text-lg">{item.title}</h3>

          {item.description && (
  <p
    class="text-slate-500 mt-2 leading-relaxed"
    set:html={item.description}
  />
)}


          {item.items && (
            <ul class="mt-2 space-y-1">
              {item.items.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-slate-500 hover:text-[#F15D2D] hover:underline"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>
    ))
  }
</div>
